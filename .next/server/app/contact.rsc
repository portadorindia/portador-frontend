3e:["$","details","What is air cargo movement?",{"className":"group glass-panel rounded-lg p-5","children":[["$","summary",null,{"className":"flex cursor-pointer list-none items-start justify-between gap-4 text-white","children":[["$","h3",null,{"className":"text-base font-semibold leading-7 text-white","children":"What is air cargo movement?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":18,"height":18,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down mt-1 shrink-0 text-[#e30613] transition group-open:rotate-180","aria-hidden":"true","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","p",null,{"className":"mt-4 text-sm leading-7 text-zinc-300","children":"Air cargo movement means eligible goods travel through air freight channels instead of routine surface transport. It is useful for urgent intercity shipments, business-critical parts, excess baggage, documents, medical cargo, and high-priority B2B cargo."}]]}]
