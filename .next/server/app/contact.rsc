1d:T371a,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is the fastest way to contact PORTADOR SOS?","acceptedAnswer":{"@type":"Answer","text":"For urgent cargo, call operations or send shipment details on WhatsApp so the team can check cargo, route, timing, and serviceability quickly."}},{"@type":"Question","name":"What information is needed to quote?","acceptedAnswer":{"@type":"Answer","text":"A quote needs enough detail to check urgent air cargo feasibility. Share origin, destination, deadline, cargo type, weight, dimensions, pickup address, consignee details, invoice value, delivery requirement, and any battery, liquid, chemical, medical, or dangerous goods declaration."}},{"@type":"Question","name":"Can I request a quote for same-day cargo?","acceptedAnswer":{"@type":"Answer","text":"Yes. PORTADOR SOS can check same-day air cargo feasibility once shipment and route details are available."}},{"@type":"Question","name":"Can I contact PORTADOR SOS at night?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR SOS is positioned for 24x7 urgent operations support, subject to pickup, airport, airline, and route availability."}},{"@type":"Question","name":"Can PORTADOR SOS handle urgent documents?","acceptedAnswer":{"@type":"Answer","text":"Yes. Urgent legal, tender, commercial, and business documents can be checked for same-day, NFO, or hand-carry movement."}},{"@type":"Question","name":"Can PORTADOR SOS support dangerous goods, lithium batteries, or regulated cargo?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR SOS can check dangerous goods, lithium batteries, and regulated cargo, but final movement depends on airline rules, approval, serviceability, and compliance review. MSDS or declaration may be required, and packing and documentation must be verified."}},{"@type":"Question","name":"What cargo categories can PORTADOR SOS support?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR SOS can support urgent cargo categories that are eligible for air movement and properly documented. Common categories include B2B documents, machine parts, laptops, medical equipment, excess baggage, high-value cargo, lithium battery shipments, dangerous goods, event cargo, and aviation spares."}},{"@type":"Question","name":"What affects urgent air cargo feasibility?","acceptedAnswer":{"@type":"Answer","text":"Urgent air cargo feasibility depends on timing, cargo eligibility, documentation, serviceability, regulatory compliance verification, and available air movement. PORTADOR SOS confirms feasibility before committing to movement."}},{"@type":"Question","name":"Does PORTADOR SOS support airport-to-airport cargo?","acceptedAnswer":{"@type":"Answer","text":"Yes. Airport-to-airport cargo can be coordinated for eligible shipments and routes."}},{"@type":"Question","name":"Do you arrange pickup?","acceptedAnswer":{"@type":"Answer","text":"Pickup can be arranged in supported zones depending on route, deadline, cargo readiness, and operational availability."}},{"@type":"Question","name":"Is WhatsApp enough to start?","acceptedAnswer":{"@type":"Answer","text":"Yes. WhatsApp is useful for sharing shipment details, photos, dimensions, documents, and deadlines quickly."}},{"@type":"Question","name":"Can PORTADOR help with same-day delivery?","acceptedAnswer":{"@type":"Answer","text":"Yes. PORTADOR SOS can support same-day delivery where cargo readiness, documents, serviceability, and available air movement allow. Share the city pair, deadline, cargo type, weight, dimensions, and pickup details for urgent feasibility review."}},{"@type":"Question","name":"What is air cargo movement?","acceptedAnswer":{"@type":"Answer","text":"Air cargo movement means eligible goods travel through air freight channels instead of routine surface transport. It is useful for urgent intercity shipments, business-critical parts, excess baggage, documents, medical cargo, and high-priority B2B cargo."}},{"@type":"Question","name":"What is airport cargo?","acceptedAnswer":{"@type":"Answer","text":"Airport cargo is shipment movement connected to airport cargo facilities and air freight options. It can help urgent cargo move faster between major cities where serviceability, documentation, cargo type, and acceptance conditions allow."}},{"@type":"Question","name":"When is air cargo better than courier?","acceptedAnswer":{"@type":"Answer","text":"Air cargo is better than courier when the shipment has a hard deadline, long intercity distance, business downtime risk, or urgent receiver requirement. Routine courier is suitable for normal parcels without immediate time pressure."}},{"@type":"Question","name":"Can PORTADOR ship excess baggage?","acceptedAnswer":{"@type":"Answer","text":"Yes. PORTADOR can support excess baggage shipping for domestic and international travel situations where contents are eligible, packed correctly, documented, and accepted for movement. Share baggage count, weight, route, deadline, and contents."}},{"@type":"Question","name":"Can students send baggage with PORTADOR?","acceptedAnswer":{"@type":"Answer","text":"Yes. Students can request baggage movement support for relocation, college moves, missed baggage situations, or urgent personal goods. Feasibility depends on contents, packing, documents, pickup city, destination, and timeline."}},{"@type":"Question","name":"Can PORTADOR help with relocation cargo?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR can check relocation cargo when items are air-eligible and time-sensitive. It is best for urgent personal goods, student baggage, priority cartons, documents, electronics, and selected household items, not bulk household shifting."}},{"@type":"Question","name":"Can PORTADOR move personal goods?","acceptedAnswer":{"@type":"Answer","text":"Yes. PORTADOR can check personal goods where items are legally permitted, packed correctly, declared accurately, and serviceable. Restricted or prohibited items cannot be accepted, and some categories may need documentation."}},{"@type":"Question","name":"Can household items move by air cargo?","acceptedAnswer":{"@type":"Answer","text":"Selected household items can move by air cargo when they are permitted, properly packed, and documented. Large-volume household shifting is usually better suited to surface movement, while urgent boxes or essential items may be reviewed."}},{"@type":"Question","name":"Can PORTADOR ship laptops?","acceptedAnswer":{"@type":"Answer","text":"Yes. Laptop shipping can be checked where packing, invoice details, battery declaration, and serviceability are acceptable. Lithium batteries inside devices may require declaration and airline approval depending on quantity and conditions."}},{"@type":"Question","name":"Can PORTADOR ship mobile phones?","acceptedAnswer":{"@type":"Answer","text":"Mobile phone shipping can be checked if the device is properly packed, declared, and accepted under applicable battery and electronics rules. Quantity, invoice value, and lithium battery conditions may affect acceptance."}},{"@type":"Question","name":"Can dangerous goods move with PORTADOR?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR can review dangerous goods cargo, but movement depends on classification, documentation, packing, approvals, and service feasibility. MSDS, declaration, invoice, and compliance details may be required before acceptance."}},{"@type":"Question","name":"Can lithium batteries move by air?","acceptedAnswer":{"@type":"Answer","text":"Lithium batteries can move by air only when the battery type, rating, packing, quantity, documents, and approvals meet applicable rules. PORTADOR can check battery cargo but cannot accept it without compliance review."}},{"@type":"Question","name":"Does PORTADOR provide warehousing?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR may check temporary holding or warehousing support for selected shipments where location, duration, cargo type, compliance requirements, and urgency allow. Share shipment details for availability review."}},{"@type":"Question","name":"Can PORTADOR arrange reverse pickup?","acceptedAnswer":{"@type":"Answer","text":"Yes. Reverse pickup can be checked where pickup address, cargo readiness, documents, packing, and serviceability allow. Share pickup contact, destination, cargo details, and deadline."}},{"@type":"Question","name":"Can PORTADOR support import shipments?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR GLOBAL can check urgent import shipment support for time-sensitive international cargo. Feasibility depends on documents, customs status, commodity type, consignee readiness, compliance requirements, and available premium air freight options."}},{"@type":"Question","name":"Does PORTADOR handle customs?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR can guide customers on shipment documentation requirements and check international cargo support. Customs processes depend on commodity type, documents, duties, taxes, regulations, and appointed clearance arrangements."}},{"@type":"Question","name":"How do I track my shipment?","acceptedAnswer":{"@type":"Answer","text":"You can request tracking support by sharing your booking reference, shipment details, or contact number. PORTADOR will check the available shipment status and share updates through the operations desk."}},{"@type":"Question","name":"How fast can pickup happen?","acceptedAnswer":{"@type":"Answer","text":"Pickup timing depends on city, location, cargo readiness, documents, packing, traffic, and service availability. For urgent requests, share complete details immediately so PORTADOR can check the fastest feasible support."}},{"@type":"Question","name":"How is delivery timing confirmed?","acceptedAnswer":{"@type":"Answer","text":"Delivery timing is confirmed only after cargo details, serviceability, documentation, acceptance requirements, and receiver availability are reviewed. PORTADOR avoids false guarantees for shipments affected by external conditions."}},{"@type":"Question","name":"What is volumetric weight?","acceptedAnswer":{"@type":"Answer","text":"Volumetric weight is a billing weight based on package size rather than only actual weight. Large lightweight boxes may be charged by volumetric weight because they occupy more cargo space."}},{"@type":"Question","name":"Is E-Way Bill required?","acceptedAnswer":{"@type":"Answer","text":"E-Way Bill may be required for commercial goods depending on invoice value, commodity type, origin, destination, and applicable GST rules. Customers should provide required tax documents before shipment movement."}},{"@type":"Question","name":"Does PORTADOR provide insurance?","acceptedAnswer":{"@type":"Answer","text":"Insurance or declared-value protection may be available only when agreed and documented before shipment movement. High-value cargo should be declared accurately, and customers should review liability terms before booking."}},{"@type":"Question","name":"What is FOV?","acceptedAnswer":{"@type":"Answer","text":"FOV means Freight on Value or declared-value handling charges for eligible shipments. Where applicable, FOV may be charged based on invoice value and accepted terms before shipment movement."}},{"@type":"Question","name":"What is Carrier Risk?","acceptedAnswer":{"@type":"Answer","text":"Carrier Risk is a declared-value risk option that may be available at 5% of invoice value for eligible shipments, subject to written acceptance and policy conditions. It must be confirmed before booking."}},{"@type":"Question","name":"What is Own Risk?","acceptedAnswer":{"@type":"Answer","text":"Own Risk means the shipment moves without additional declared-value carrier risk coverage beyond standard liability terms. Customers should review policy limits before booking high-value or sensitive shipments."}},{"@type":"Question","name":"Which items are prohibited?","acceptedAnswer":{"@type":"Answer","text":"Prohibited items include goods banned by law, unsafe items, undeclared dangerous goods, restricted substances, and items not accepted by relevant carriers or authorities. Customers must review the Restricted Goods page before booking."}},{"@type":"Question","name":"How does the refund policy work?","acceptedAnswer":{"@type":"Answer","text":"Refund eligibility depends on booking status, cancellation timing, service attempt, shipment acceptance, and policy terms. Customers should review the Booking & Refund Policy for liability, cancellation, claim, and refund conditions."}},{"@type":"Question","name":"What payment methods are accepted?","acceptedAnswer":{"@type":"Answer","text":"Payment methods may include bank transfer, UPI, or other accepted business payment options shared during booking. Shipment movement may require payment confirmation before service execution."}},{"@type":"Question","name":"Can PORTADOR provide a GST invoice?","acceptedAnswer":{"@type":"Answer","text":"Yes. PORTADOR can provide GST invoice support for eligible commercial bookings where correct billing details, GSTIN, company name, address, and shipment information are provided."}},{"@type":"Question","name":"Can PORTADOR support commercial B2B shipments?","acceptedAnswer":{"@type":"Answer","text":"Yes. PORTADOR supports urgent commercial and B2B shipments such as machine parts, electronics, samples, documents, medical equipment, aviation spares, event material, and high-value cargo where serviceability allows."}},{"@type":"Question","name":"Can medical cargo move with PORTADOR?","acceptedAnswer":{"@type":"Answer","text":"Medical cargo can be checked where the item is permitted, documented, packed correctly, and accepted for movement. Temperature sensitivity, device value, urgency, and compliance requirements must be declared clearly."}},{"@type":"Question","name":"Can PORTADOR move high-value cargo?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR can check high-value cargo where declaration, packaging, documentation, receiver details, risk terms, and serviceability are clear. High-value shipments should be declared accurately before acceptance."}}]}a:["$","$1","c",{"children":[["$","main",null,{"children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1d"}}],"$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28"]}],null,"$L29"]}]
