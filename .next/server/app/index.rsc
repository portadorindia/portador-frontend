8b:["$","details","How is delivery timing confirmed?",{"className":"group glass-panel rounded-lg p-5","children":[["$","summary",null,{"className":"flex cursor-pointer list-none items-start justify-between gap-4 text-white","children":[["$","h3",null,{"className":"text-base font-semibold leading-7 text-white","children":"How is delivery timing confirmed?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":18,"height":18,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down mt-1 shrink-0 text-[#e30613] transition group-open:rotate-180","aria-hidden":"true","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","p",null,{"className":"mt-4 text-sm leading-7 text-zinc-300","children":"Delivery timing is confirmed only after cargo details, serviceability, documentation, acceptance requirements, and receiver availability are reviewed. PORTADOR avoids false guarantees for shipments affected by external conditions."}]]}]
