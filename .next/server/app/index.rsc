1c:T593c,[{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How to send urgent cargo today?","acceptedAnswer":{"@type":"Answer","text":"Send urgent cargo today by sharing origin, destination, deadline, cargo category, weight, dimensions, and documents with PORTADOR SOS. The operations desk checks whether urgent same-day or next-flight-out air cargo support is feasible for the shipment."}},{"@type":"Question","name":"How to send parcel by flight?","acceptedAnswer":{"@type":"Answer","text":"A parcel can move by flight when it is air-eligible, properly packed, documented, and accepted for air cargo movement. PORTADOR SOS checks same-day air cargo, next flight out options, airport-to-airport cargo, and urgent door support where feasible."}},{"@type":"Question","name":"What is same-day air cargo?","acceptedAnswer":{"@type":"Answer","text":"Same-day air cargo is urgent air-linked cargo movement planned to reach the destination the same day where timing, cargo eligibility, documentation, and serviceability allow. PORTADOR SOS uses this for business downtime, machine breakdown, missed flight baggage, and emergency replacement situations."}},{"@type":"Question","name":"What is next flight out cargo?","acceptedAnswer":{"@type":"Answer","text":"Next Flight Out cargo is urgent air logistics where a shipment is routed through the earliest suitable airline connection. It is used when routine courier hub movement or overnight schedules are too slow for the shipment deadline."}},{"@type":"Question","name":"What is airport-to-airport cargo?","acceptedAnswer":{"@type":"Answer","text":"Airport-to-airport cargo moves eligible shipments between airport cargo terminals using airline cargo channels. It can reduce avoidable hub delays when the receiver can collect at destination airport or when connected delivery is coordinated after flight movement."}},{"@type":"Question","name":"When should I use PORTADOR SOS?","acceptedAnswer":{"@type":"Answer","text":"Use PORTADOR SOS when delay can create business downtime, production loss, missed flights, tender failure, emergency replacement failure, or customer escalation. It is built for urgent domestic air cargo where operational urgency matters more than routine courier scale."}},{"@type":"Question","name":"Can PORTADOR move cargo in 10-16 hours?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR SOS can check 10-16 hour urgent cargo movement feasibility on major airport-connected lanes where timing allows. Final feasibility depends on cargo readiness, eligibility, documentation, available air movement, and destination serviceability."}},{"@type":"Question","name":"Can PORTADOR support dangerous goods, lithium batteries, or regulated cargo?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR can support dangerous goods, lithium batteries, and regulated cargo after compliance review, but acceptance depends on airline rules and approvals. MSDS or declaration may be required, packing and documentation must be verified, and final movement depends on approval and serviceability."}},{"@type":"Question","name":"How does PORTADOR reduce hub delays?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR reduces avoidable hub delays by prioritizing airport-linked air cargo support where feasible instead of routine multi-hub courier movement. Human operations coordination helps urgent shipments move with clearer accountability."}},{"@type":"Question","name":"Why regular courier fails for urgent shipments?","acceptedAnswer":{"@type":"Answer","text":"Regular courier can be too slow for urgent shipments because routine networks optimize pickup density, hub sorting, and scheduled linehaul movement. PORTADOR SOS is used when same-day air cargo, next flight out support, and human support are needed."}},{"@type":"Question","name":"What information is needed for an urgent quote?","acceptedAnswer":{"@type":"Answer","text":"An urgent quote needs origin, destination, deadline, cargo type, weight, dimensions, pickup address, receiver details, invoice value, packing status, and any battery, dangerous goods, medical, liquid, or regulated cargo declaration. These details help PORTADOR SOS check urgent air cargo feasibility accurately."}},{"@type":"Question","name":"Who should use PORTADOR BLACK?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR BLACK is for founders, CEOs, HNIs, UHNWIs, family offices, legal teams, and high-value cargo clients who need hand carry, OBC, runner, VIP, confidential, or short-notice logistics. It is used when personal custody, fewer handoffs, and discreet coordination matter."}},{"@type":"Question","name":"When should businesses use PORTADOR EXPRESS?","acceptedAnswer":{"@type":"Answer","text":"Businesses should use PORTADOR EXPRESS for next business day or second business day premium air cargo when the shipment is important but not a same-day emergency. It fits priority B2B cargo, 10kg-100kg+ shipments, commercial samples, electronics, parts, and planned urgent movement."}},{"@type":"Question","name":"What is urgent international air cargo?","acceptedAnswer":{"@type":"Answer","text":"Urgent international air cargo is premium import or export air freight planned for cross-border shipments with tight deadlines. PORTADOR GLOBAL coordinates documentation review, compliance checks, premium air freight support, and receiver-side coordination for time-sensitive international cargo."}},{"@type":"Question","name":"What cargo categories can PORTADOR support?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR can support urgent cargo categories that are air-eligible, properly packed, and documented. Common categories include excess baggage, battery cargo, dangerous goods, perishables, temperature controlled cargo, medical equipment, AOG cargo, machine parts, tender documents, hand carry / OBC, air cargo charter, laptop shipping, and high-value cargo."}},{"@type":"Question","name":"Is same-day delivery always feasible?","acceptedAnswer":{"@type":"Answer","text":"Same-day delivery is not always feasible. PORTADOR SOS confirms serviceability based on cargo readiness, documents, available air movement, destination support, and regulatory requirements before accepting an urgent shipment."}},{"@type":"Question","name":"Can PORTADOR help with tracking?","acceptedAnswer":{"@type":"Answer","text":"Yes. PORTADOR can support tracking for urgent shipments handled through PORTADOR SOS, EXPRESS, BLACK, or GLOBAL. Customers should share the shipment reference or booking details for the fastest status check."}},{"@type":"Question","name":"Can PORTADOR arrange reverse pickup?","acceptedAnswer":{"@type":"Answer","text":"Reverse pickup can be checked where the pickup location, cargo readiness, documentation, and serviceability allow. Share pickup address, consignee details, cargo type, deadline, and packing status for review."}},{"@type":"Question","name":"Does PORTADOR provide warehousing?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR may support warehousing or temporary holding for selected shipments where operationally feasible. Availability depends on location, cargo type, duration, compliance requirements, and shipment urgency."}},{"@type":"Question","name":"Can PORTADOR support import shipments?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR GLOBAL can support urgent international import air cargo. Import feasibility depends on documents, commodity type, customs status, consignee readiness, regulatory requirements, and available premium air cargo options."}},{"@type":"Question","name":"Can PORTADOR move personal goods?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR can move personal goods, excess baggage, student relocation cargo, and urgent travel-related shipments where the items are air-eligible, properly packed, documented, and accepted for movement."}},{"@type":"Question","name":"What is PORTADOR liability per docket?","acceptedAnswer":{"@type":"Answer","text":"Unless separately agreed in writing, liability may be limited to Rs. 2,500 per docket as described in the Booking & Refund Policy. Customers should review the policy before booking high-value shipments."}},{"@type":"Question","name":"What is Carrier Risk or FOV?","acceptedAnswer":{"@type":"Answer","text":"Carrier Risk or FOV may be available at 5% of invoice value for declared eligible shipments, subject to acceptance and written confirmation. Coverage terms depend on shipment details and policy conditions."}},{"@type":"Question","name":"Can PORTADOR help with same-day delivery?","acceptedAnswer":{"@type":"Answer","text":"Yes. PORTADOR SOS can support same-day delivery where cargo readiness, documents, serviceability, and available air movement allow. Share the city pair, deadline, cargo type, weight, dimensions, and pickup details for urgent feasibility review."}},{"@type":"Question","name":"What is air cargo movement?","acceptedAnswer":{"@type":"Answer","text":"Air cargo movement means eligible goods travel through air freight channels instead of routine surface transport. It is useful for urgent intercity shipments, business-critical parts, excess baggage, documents, medical cargo, and high-priority B2B cargo."}},{"@type":"Question","name":"What is airport cargo?","acceptedAnswer":{"@type":"Answer","text":"Airport cargo is shipment movement connected to airport cargo facilities and air freight options. It can help urgent cargo move faster between major cities where serviceability, documentation, cargo type, and acceptance conditions allow."}},{"@type":"Question","name":"When is air cargo better than courier?","acceptedAnswer":{"@type":"Answer","text":"Air cargo is better than courier when the shipment has a hard deadline, long intercity distance, business downtime risk, or urgent receiver requirement. Routine courier is suitable for normal parcels without immediate time pressure."}},{"@type":"Question","name":"Can PORTADOR ship excess baggage?","acceptedAnswer":{"@type":"Answer","text":"Yes. PORTADOR can support excess baggage shipping for domestic and international travel situations where contents are eligible, packed correctly, documented, and accepted for movement. Share baggage count, weight, route, deadline, and contents."}},{"@type":"Question","name":"Can students send baggage with PORTADOR?","acceptedAnswer":{"@type":"Answer","text":"Yes. Students can request baggage movement support for relocation, college moves, missed baggage situations, or urgent personal goods. Feasibility depends on contents, packing, documents, pickup city, destination, and timeline."}},{"@type":"Question","name":"Can PORTADOR help with relocation cargo?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR can check relocation cargo when items are air-eligible and time-sensitive. It is best for urgent personal goods, student baggage, priority cartons, documents, electronics, and selected household items, not bulk household shifting."}},{"@type":"Question","name":"Can PORTADOR move personal goods?","acceptedAnswer":{"@type":"Answer","text":"Yes. PORTADOR can check personal goods where items are legally permitted, packed correctly, declared accurately, and serviceable. Restricted or prohibited items cannot be accepted, and some categories may need documentation."}},{"@type":"Question","name":"Can household items move by air cargo?","acceptedAnswer":{"@type":"Answer","text":"Selected household items can move by air cargo when they are permitted, properly packed, and documented. Large-volume household shifting is usually better suited to surface movement, while urgent boxes or essential items may be reviewed."}},{"@type":"Question","name":"Can PORTADOR ship laptops?","acceptedAnswer":{"@type":"Answer","text":"Yes. Laptop shipping can be checked where packing, invoice details, battery declaration, and serviceability are acceptable. Lithium batteries inside devices may require declaration and airline approval depending on quantity and conditions."}},{"@type":"Question","name":"Can PORTADOR ship mobile phones?","acceptedAnswer":{"@type":"Answer","text":"Mobile phone shipping can be checked if the device is properly packed, declared, and accepted under applicable battery and electronics rules. Quantity, invoice value, and lithium battery conditions may affect acceptance."}},{"@type":"Question","name":"Can dangerous goods move with PORTADOR?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR can review dangerous goods cargo, but movement depends on classification, documentation, packing, approvals, and service feasibility. MSDS, declaration, invoice, and compliance details may be required before acceptance."}},{"@type":"Question","name":"Can lithium batteries move by air?","acceptedAnswer":{"@type":"Answer","text":"Lithium batteries can move by air only when the battery type, rating, packing, quantity, documents, and approvals meet applicable rules. PORTADOR can check battery cargo but cannot accept it without compliance review."}},{"@type":"Question","name":"Does PORTADOR provide warehousing?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR may check temporary holding or warehousing support for selected shipments where location, duration, cargo type, compliance requirements, and urgency allow. Share shipment details for availability review."}},{"@type":"Question","name":"Can PORTADOR arrange reverse pickup?","acceptedAnswer":{"@type":"Answer","text":"Yes. Reverse pickup can be checked where pickup address, cargo readiness, documents, packing, and serviceability allow. Share pickup contact, destination, cargo details, and deadline."}},{"@type":"Question","name":"Can PORTADOR support import shipments?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR GLOBAL can check urgent import shipment support for time-sensitive international cargo. Feasibility depends on documents, customs status, commodity type, consignee readiness, compliance requirements, and available premium air freight options."}},{"@type":"Question","name":"Does PORTADOR handle customs?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR can guide customers on shipment documentation requirements and check international cargo support. Customs processes depend on commodity type, documents, duties, taxes, regulations, and appointed clearance arrangements."}},{"@type":"Question","name":"How do I track my shipment?","acceptedAnswer":{"@type":"Answer","text":"You can request tracking support by sharing your booking reference, shipment details, or contact number. PORTADOR will check the available shipment status and share updates through the operations desk."}},{"@type":"Question","name":"How fast can pickup happen?","acceptedAnswer":{"@type":"Answer","text":"Pickup timing depends on city, location, cargo readiness, documents, packing, traffic, and service availability. For urgent requests, share complete details immediately so PORTADOR can check the fastest feasible support."}},{"@type":"Question","name":"How is delivery timing confirmed?","acceptedAnswer":{"@type":"Answer","text":"Delivery timing is confirmed only after cargo details, serviceability, documentation, acceptance requirements, and receiver availability are reviewed. PORTADOR avoids false guarantees for shipments affected by external conditions."}},{"@type":"Question","name":"What is volumetric weight?","acceptedAnswer":{"@type":"Answer","text":"Volumetric weight is a billing weight based on package size rather than only actual weight. Large lightweight boxes may be charged by volumetric weight because they occupy more cargo space."}},{"@type":"Question","name":"Is E-Way Bill required?","acceptedAnswer":{"@type":"Answer","text":"E-Way Bill may be required for commercial goods depending on invoice value, commodity type, origin, destination, and applicable GST rules. Customers should provide required tax documents before shipment movement."}},{"@type":"Question","name":"Does PORTADOR provide insurance?","acceptedAnswer":{"@type":"Answer","text":"Insurance or declared-value protection may be available only when agreed and documented before shipment movement. High-value cargo should be declared accurately, and customers should review liability terms before booking."}},{"@type":"Question","name":"What is FOV?","acceptedAnswer":{"@type":"Answer","text":"FOV means Freight on Value or declared-value handling charges for eligible shipments. Where applicable, FOV may be charged based on invoice value and accepted terms before shipment movement."}},{"@type":"Question","name":"What is Carrier Risk?","acceptedAnswer":{"@type":"Answer","text":"Carrier Risk is a declared-value risk option that may be available at 5% of invoice value for eligible shipments, subject to written acceptance and policy conditions. It must be confirmed before booking."}},{"@type":"Question","name":"What is Own Risk?","acceptedAnswer":{"@type":"Answer","text":"Own Risk means the shipment moves without additional declared-value carrier risk coverage beyond standard liability terms. Customers should review policy limits before booking high-value or sensitive shipments."}},{"@type":"Question","name":"Which items are prohibited?","acceptedAnswer":{"@type":"Answer","text":"Prohibited items include goods banned by law, unsafe items, undeclared dangerous goods, restricted substances, and items not accepted by relevant carriers or authorities. Customers must review the Restricted Goods page before booking."}},{"@type":"Question","name":"How does the refund policy work?","acceptedAnswer":{"@type":"Answer","text":"Refund eligibility depends on booking status, cancellation timing, service attempt, shipment acceptance, and policy terms. Customers should review the Booking & Refund Policy for liability, cancellation, claim, and refund conditions."}},{"@type":"Question","name":"What payment methods are accepted?","acceptedAnswer":{"@type":"Answer","text":"Payment methods may include bank transfer, UPI, or other accepted business payment options shared during booking. Shipment movement may require payment confirmation before service execution."}},{"@type":"Question","name":"Can PORTADOR provide a GST invoice?","acceptedAnswer":{"@type":"Answer","text":"Yes. PORTADOR can provide GST invoice support for eligible commercial bookings where correct billing details, GSTIN, company name, address, and shipment information are provided."}},{"@type":"Question","name":"Can PORTADOR support commercial B2B shipments?","acceptedAnswer":{"@type":"Answer","text":"Yes. PORTADOR supports urgent commercial and B2B shipments such as machine parts, electronics, samples, documents, medical equipment, aviation spares, event material, and high-value cargo where serviceability allows."}},{"@type":"Question","name":"Can medical cargo move with PORTADOR?","acceptedAnswer":{"@type":"Answer","text":"Medical cargo can be checked where the item is permitted, documented, packed correctly, and accepted for movement. Temperature sensitivity, device value, urgency, and compliance requirements must be declared clearly."}},{"@type":"Question","name":"Can PORTADOR move high-value cargo?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR can check high-value cargo where declaration, packaging, documentation, receiver details, risk terms, and serviceability are clear. High-value shipments should be declared accurately before acceptance."}}]},{"@context":"https://schema.org","@type":"Service","name":"PORTADOR SOS Air Cargo","description":"Same-day air cargo, Next Flight Out coordination, urgent airport cargo support, and 24x7 human operations for urgent shipments across India.","provider":{"@type":"Organization","name":"PORTADOR SOS","url":"https://portador.in","telephone":"+91 9403892974","email":"growth@portador.in"},"areaServed":{"@type":"Country","name":"India"},"serviceType":"PORTADOR SOS Air Cargo","serviceOutput":"Airport-linked air cargo support, real-time monitoring, human operations desk coordination, and regulated cargo review where relevant.","hasOfferCatalog":{"@type":"OfferCatalog","name":"PORTADOR SOS premium air cargo services","itemListElement":[{"@type":"Offer","itemOffered":{"@type":"Service","name":"PORTADOR SOS","areaServed":"India","serviceType":"Same-Day Air Cargo + Next Flight Out Logistics","description":"Flagship emergency domestic air cargo service for same-day, NFO, 10-16 hour feasibility where possible, airport-to-airport movement, urgent door coordination, and 24x7 human operations.","serviceOutput":"Airport-linked air cargo support, real-time monitoring, regulatory compliance verification where relevant, and human operations desk support for urgent cargo."}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"PORTADOR EXPRESS","areaServed":"India","serviceType":"Next Business Day & Second Business Day Premium Air Cargo","description":"Premium air-priority movement for planned B2B cargo, 10kg-100kg+ shipments, and reliable next business day or second business day cargo.","serviceOutput":"Airport-linked air cargo support, real-time monitoring, regulatory compliance verification where relevant, and human operations desk support for urgent cargo."}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"PORTADOR BLACK","areaServed":"India","serviceType":"OBC / Hand Carry / Runner / VIP Short-Notice Logistics","description":"VIP hand-carry and runner logistics for founders, CEOs, HNIs, UHNWIs, family offices, confidential cargo, and high-value shipments.","serviceOutput":"Airport-linked air cargo support, real-time monitoring, regulatory compliance verification where relevant, and human operations desk support for urgent cargo."}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"PORTADOR GLOBAL","areaServed":"India","serviceType":"Urgent International Import / Export Air Cargo","description":"Urgent cross-border air cargo coordination for premium international air freight, import/export movement, documentation review, and compliance-aware shipment planning.","serviceOutput":"Airport-linked air cargo support, real-time monitoring, regulatory compliance verification where relevant, and human operations desk support for urgent cargo."}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Secondary Cargo Categories","areaServed":"India","serviceType":"Excess Baggage, Dangerous Goods, Batteries & Restricted Cargo, Perishables, Temperature Controlled Cargo, Medical Equipment, AOG Cargo, Machine Parts, Legal Documents, Air Cargo Charter, High-Value Cargo","description":"Cargo categories checked under PORTADOR SOS, EXPRESS, BLACK, or GLOBAL based on urgency, documents, packing, compliance requirements, and serviceability.","serviceOutput":"Airport-linked air cargo support, real-time monitoring, regulatory compliance verification where relevant, and human operations desk support for urgent cargo."}}]},"url":"https://portador.in/"}]9:["$","$1","c",{"children":[["$","main",null,{"children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1c"}}],"$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e"]}],null,"$L2f"]}]
