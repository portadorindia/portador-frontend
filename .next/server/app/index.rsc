7f:["$","details","Can PORTADOR move personal goods?",{"className":"group glass-panel rounded-lg p-5","children":[["$","summary",null,{"className":"flex cursor-pointer list-none items-start justify-between gap-4 text-white","children":[["$","h3",null,{"className":"text-base font-semibold leading-7 text-white","children":"Can PORTADOR move personal goods?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":18,"height":18,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down mt-1 shrink-0 text-[#e30613] transition group-open:rotate-180","aria-hidden":"true","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","p",null,{"className":"mt-4 text-sm leading-7 text-zinc-300","children":"Yes. PORTADOR can check personal goods where items are legally permitted, packed correctly, declared accurately, and serviceable. Restricted or prohibited items cannot be accepted, and some categories may need documentation."}]]}]
80:["$","details","Can household items move by air cargo?",{"className":"group glass-panel rounded-lg p-5","children":[["$","summary",null,{"className":"flex cursor-pointer list-none items-start justify-between gap-4 text-white","children":[["$","h3",null,{"className":"text-base font-semibold leading-7 text-white","children":"Can household items move by air cargo?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":18,"height":18,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down mt-1 shrink-0 text-[#e30613] transition group-open:rotate-180","aria-hidden":"true","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","p",null,{"className":"mt-4 text-sm leading-7 text-zinc-300","children":"Selected household items can move by air cargo when they are permitted, properly packed, and documented. Large-volume household shifting is usually better suited to surface movement, while urgent boxes or essential items may be reviewed."}]]}]
81:["$","details","Can PORTADOR ship laptops?",{"className":"group glass-panel rounded-lg p-5","children":[["$","summary",null,{"className":"flex cursor-pointer list-none items-start justify-between gap-4 text-white","children":[["$","h3",null,{"className":"text-base font-semibold leading-7 text-white","children":"Can PORTADOR ship laptops?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":18,"height":18,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down mt-1 shrink-0 text-[#e30613] transition group-open:rotate-180","aria-hidden":"true","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","p",null,{"className":"mt-4 text-sm leading-7 text-zinc-300","children":"Yes. Laptop shipping can be checked where packing, invoice details, battery declaration, and serviceability are acceptable. Lithium batteries inside devices may require declaration and airline approval depending on quantity and conditions."}]]}]
