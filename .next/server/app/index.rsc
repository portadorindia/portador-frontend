2:T2da8,[{"@context":"https://schema.org","@type":"Organization","name":"PORTADOR SOS","legalName":"PORTADOR Logistics Pvt. Ltd.","url":"https://portador.in","logo":"https://portador.in/portador-logo.png","email":"growth@portador.in","telephone":"+91 9403892974","address":{"@type":"PostalAddress","streetAddress":"Innov8, Okhla Industrial Estate Phase 3","addressLocality":"New Delhi","postalCode":"110020","addressCountry":"India"},"slogan":"When Time Cannot Wait.","description":"Premium SOS air cargo operations platform specializing in PORTADOR SOS same-day air cargo, next flight out coordination, airport cargo support, PORTADOR EXPRESS, PORTADOR BLACK, PORTADOR GLOBAL, regulated cargo review, and mission-critical shipments across India.","areaServed":"India","contactPoint":{"@type":"ContactPoint","telephone":"+91 9403892974","email":"growth@portador.in","contactType":"customer support","areaServed":"IN","availableLanguage":["en","hi"]},"hasOfferCatalog":{"@type":"OfferCatalog","name":"PORTADOR SOS premium air cargo services","itemListElement":[{"@type":"Offer","itemOffered":{"@type":"Service","name":"PORTADOR SOS","areaServed":"India","serviceType":"Same-Day Air Cargo + Next Flight Out Logistics","description":"Flagship emergency domestic air cargo service for same-day, NFO, 10-16 hour feasibility where possible, airport-to-airport movement, urgent door coordination, and 24x7 human operations.","serviceOutput":"Airport-linked air cargo support, real-time monitoring, regulatory compliance verification where relevant, and human operations desk support for urgent cargo."}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"PORTADOR EXPRESS","areaServed":"India","serviceType":"Next Business Day & Second Business Day Premium Air Cargo","description":"Premium air-priority movement for planned B2B cargo, 10kg-100kg+ shipments, and reliable next business day or second business day cargo.","serviceOutput":"Airport-linked air cargo support, real-time monitoring, regulatory compliance verification where relevant, and human operations desk support for urgent cargo."}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"PORTADOR BLACK","areaServed":"India","serviceType":"OBC / Hand Carry / Runner / VIP Short-Notice Logistics","description":"VIP hand-carry and runner logistics for founders, CEOs, HNIs, UHNWIs, family offices, confidential cargo, and high-value shipments.","serviceOutput":"Airport-linked air cargo support, real-time monitoring, regulatory compliance verification where relevant, and human operations desk support for urgent cargo."}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"PORTADOR GLOBAL","areaServed":"India","serviceType":"Urgent International Import / Export Air Cargo","description":"Urgent cross-border air cargo coordination for premium international air freight, import/export movement, documentation review, and compliance-aware shipment planning.","serviceOutput":"Airport-linked air cargo support, real-time monitoring, regulatory compliance verification where relevant, and human operations desk support for urgent cargo."}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Secondary Cargo Categories","areaServed":"India","serviceType":"Excess Baggage, Dangerous Goods, Batteries & Restricted Cargo, Perishables, Temperature Controlled Cargo, Medical Equipment, AOG Cargo, Machine Parts, Legal Documents, Air Cargo Charter, High-Value Cargo","description":"Cargo categories checked under PORTADOR SOS, EXPRESS, BLACK, or GLOBAL based on urgency, documents, packing, compliance requirements, and serviceability.","serviceOutput":"Airport-linked air cargo support, real-time monitoring, regulatory compliance verification where relevant, and human operations desk support for urgent cargo."}}]},"sameAs":["https://portador.in","https://maps.app.goo.gl/8NYstBm3itwBkDNH7","https://www.youtube.com/@portadorbharat","https://www.instagram.com/portadorsos","https://www.linkedin.com/company/portador"]},{"@