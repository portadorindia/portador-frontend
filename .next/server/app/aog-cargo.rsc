28:T15d5,[{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://portador.in/"},{"@type":"ListItem","position":2,"name":"AOG Cargo","item":"https://portador.in/aog-cargo"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"When should I use PORTADOR SOS for aog cargo?","acceptedAnswer":{"@type":"Answer","text":"Use PORTADOR SOS for aog cargo when the shipment deadline is urgent and routine courier timing may not protect the outcome. Share complete cargo details so feasibility can be checked quickly."}},{"@type":"Question","name":"What details are needed for aog cargo?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR needs origin, destination, cargo type, weight, dimensions, invoice value, deadline, pickup contact, receiver details, and any battery, DG, medical, liquid, or regulated cargo declaration."}},{"@type":"Question","name":"Is aog cargo always possible?","acceptedAnswer":{"@type":"Answer","text":"AOG Cargo depends on serviceability, cargo eligibility, packing, documents, timing, and operational availability. PORTADOR SOS checks feasibility before confirming movement."}},{"@type":"Question","name":"Can PORTADOR provide door-to-door support for aog cargo?","acceptedAnswer":{"@type":"Answer","text":"Door-to-door support can be checked where pickup and delivery serviceability allow. Some urgent shipments may need airport-linked or hand carry options depending on cargo and deadline."}}]},{"@context":"https://schema.org","@type":"Service","name":"AOG Cargo","description":"Urgent aviation spares and aircraft-on-ground cargo support for parts, tooling, and critical aviation shipments. PORTADOR SOS helps customers check urgent air cargo feasibility when time cannot wait.","provider":{"@type":"Organization","name":"PORTADOR SOS","url":"https://portador.in","telephone":"+91 9403892974","email":"growth@portador.in"},"areaServed":{"@type":"C