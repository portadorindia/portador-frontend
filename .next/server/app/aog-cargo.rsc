rgo","description":"Urgent cross-border air cargo coordination for premium international air freight, import/export movement, documentation review, and compliance-aware shipment planning.","serviceOutput":"Airport-linked air cargo support, real-time monitoring, regulatory compliance verification where relevant, and human operations desk support for urgent cargo."}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Secondary Cargo Categories","areaServed":"India","serviceType":"Excess Baggage, Dangerous Goods, Batteries & Restricted Cargo, Perishables, Temperature Controlled Cargo, Medical Equipment, AOG Cargo, Machine Parts, Legal Documents, Air Cargo Charter, High-Value Cargo","description":"Cargo categories checked under PORTADOR SOS, EXPRESS, BLACK, or GLOBAL based on urgency, documents, packing, compliance requirements, and serviceability.","serviceOutput":"Airport-linked air cargo support, real-time monitoring, regulatory compliance verification where relevant, and human operations desk support for urgent cargo."}}]},"url":"https://portador.in/aog-cargo"},{"@context":"https://schema.org","@type":"WebPage","name":"AOG Cargo","description":"Urgent aviation spares and aircraft-on-ground cargo support for parts, tooling, and critical aviation shipments. PORTADOR SOS helps customers check urgent air cargo feasibility when time cannot wait.","url":"https://portador.in/aog-cargo","isPartOf":{"@type":"WebSite","name":"PORTADOR SOS","url":"https://portador.in"},"about":["urgent air cargo","same-day air cargo","airport cargo","PORTADOR SOS","time-critical logistics"]}]1d:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$28"}}],"$L29"]
