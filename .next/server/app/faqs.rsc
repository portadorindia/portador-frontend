3d:["$","details","When is airport-to-airport cargo better than courier?",{"className":"group glass-panel rounded-lg p-5","children":[["$","summary",null,{"className":"flex cursor-pointer list-none items-start justify-between gap-4 text-white","children":[["$","h3",null,{"className":"text-base font-semibold leading-7 text-white","children":"When is airport-to-airport cargo better than courier?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":18,"height":18,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down mt-1 shrink-0 text-[#e30613] transition group-open:rotate-180","aria-hidden":"true","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","div",null,{"className":"mt-4 text-sm leading-7 text-zinc-300","children":[["$","p",null,{"children":"Airport-to-airport cargo is better when fast intercity movement and terminal delivery matter more than routine door-to-door courier flow."}],["$","ul",null,{"className":"mt-3 list-disc space-y-2 pl-5","children":[["$","li","The shipment can be handed over at an airport cargo terminal.",{"children":"The shipment can be handed over at an airport cargo terminal."}],["$","li","Receiver-side airport pickup or connected delivery is feasible.",{"children":"Receiver-side airport pickup or connected delivery is feasible."}],["$","li","Avoiding hub transfers is more important than standard parcel convenience.",{"children":"Avoiding hub transfers is more important than standard parcel convenience."}],["$","li","Air cargo timing timing supports the deadline.",{"children":"Air cargo timing timing supports the deadline."}]]}],null]}]]}]
3e:["$","details","Why does regular courier fail for urgent shipments?",{"className":"group glass-panel rounded-lg p-5","children":[["$","summary",null,{"className":"flex cursor-pointer list-none items-start justify-between gap-4 text-white","children":[["$","h3",null,{"className":"text-base font-semibold leading-7 text-white","children":"Why does regular courier fail for urgent shipments?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":18,"height":18,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down mt-1 shrink-0 text-[#e30613] transition group-open:rotate-180","aria-hidden":"true","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","p",null,{"className":"mt-4 text-sm leading-7 text-zinc-300","children":"Regular courier can fail for urgent shipments because it optimizes parcel volume, hub routing, and scheduled linehaul. Mission-critical cargo needs airport-linked movement, air cargo timing, real-time monitoring, and human operations coordination."}]]}]
3f:["$","details","Why is air cargo faster than surface transport?",{"className":"group glass-panel rounded-lg p-5","children":[["$","summary",null,{"className":"flex cursor-pointer list-none items-start justify-between gap-4 text-white","children":[["$","h3",null,{"className":"text-base font-semibold leading-7 text-white","children":"Why is air cargo faster than surface transport?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":18,"height":18,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down mt-1 shrink-0 text-[#e30613] transition group-open:rotate-180","aria-hidden":"true","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","p",null,{"className":"mt-4 text-sm leading-7 text-zinc-300","children":"Air cargo can be faster than surface transport for urgent intercity delivery because the long-distance leg moves by flight. Feasibility still depends on pickup timing, airport cargo handling requirements, cargo eligibility, and destination support."}]]}]
40:["$","details","Why does same-day air cargo cost more?",{"className":"group glass-panel rounded-lg p-5","children":[["$","summary",null,{"className":"flex cursor-pointer list-none items-start justify-between gap-4 text-white","children":[["$","h3",null,{"className":"text-base font-semibold leading-7 text-white","children":"Why does same-day air cargo cost more?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":18,"height":18,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down mt-1 shrink-0 text-[#e30613] transition group-open:rotate-180","aria-hidden":"true","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","p",null,{"className":"mt-4 text-sm leading-7 text-zinc-300","children":"Same-day air cargo can cost more because it requires urgent human support, timing-led movement, cargo handling, air cargo movement, and active shipment updates. The cost reflects operational urgency rather than commodity parcel routing."}]]}]
