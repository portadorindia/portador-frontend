1d:Tbcc,[{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is PORTADOR SOS tracking?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR SOS tracking lets customers open shipment status in the separate PORTADOR-OPS tracking app using an AWB or tracking number."}},{"@type":"Question","name":"Where do I find my reference number?","acceptedAnswer":{"@type":"Answer","text":"Your reference number is shared by the PORTADOR SOS operations desk after shipment registration or booking confirmation."}},{"@type":"Question","name":"Is tracking handled inside PORTADOR.in?","acceptedAnswer":{"@type":"Answer","text":"No. PORTADOR.in is the marketing website only. Tracking is handled by the separate PORTADOR-OPS app at ops.portador.in."}},{"@type":"Question","name":"Can I track same-day air cargo?","acceptedAnswer":{"@type":"Answer","text":"Yes. Same-day air cargo status can be requested using the shipment reference or through the operations desk."}},{"@type":"Question","name":"Can I track airport-to-airport cargo?","acceptedAnswer":{"@type":"Answer","text":"Yes. Airport-to-airport cargo updates can include pickup, airport handover, air movement, arrival, and delivery status."}},{"@type":"Question","name":"What status updates matter most?","acceptedAnswer":{"@type":"Answer","text":"Important updates include pickup completed, airport handover, air movement, destination arrived, out for delivery, and handed over."}},{"@type":"Question","name":"Why does urgent cargo need human tracking?","acceptedAnswer":{"@type":"Answer","text":"Urgent air logistics depends on timing, airport handling, cargo eligibility, and destination readiness, so human support helps clarify shipment updates."}},{"@type":"Question","name":"Can I request proof of delivery?","acceptedAnswer":{"@type":"Answer","text":"Yes. PORTADOR SOS can coordinate proof of delivery or delivery where available for the shipment type."}},{"@type":"Question","name":"What if I do not have a reference number?","acceptedAnswer":{"@type":"Answer","text":"Contact operations with sender, receiver, route, and booking details so the team can locate the shipment."}},{"@type":"Question","name":"Does tracking cover hand carry shipments?","acceptedAnswer":{"@type":"Answer","text":"Hand carry and OBC shipments can be updated through the assigned coordinator because the movement is personally supervised."}}]},{"@context":"https://schema.org","@type":"HowTo","name":"How to track a PORTADOR shipment","description":"Enter an AWB or tracking number on PORTADOR.in to open the separate PORTADOR-OPS tracking page.","url":"https://portador.in/tracking","step":[{"@type":"HowToStep","position":1,"name":"Enter the AWB or tracking number","text":"Enter the AWB or tracking number"},{"@type":"HowToStep","position":2,"name":"Click Track","text":"Click Track"},{"@type":"HowToStep","position":3,"name":"PORTADOR.in redirects to the PORTADOR-OPS tracking page","text":"PORTADOR.in redirects to the PORTADOR-OPS tracking page"}]}]a:["$","$1","c",{"children":[["$","main",null,{"children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1d"}}],["$","section",null,{"className":"relative overflow-hidden py-14 md:py-20","children":[["$","div",null,{"className":"airport-grid absolute inset-0 opacity-70"}],"$L1e"]}],"$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26"]}],null,"$L27"]}]
