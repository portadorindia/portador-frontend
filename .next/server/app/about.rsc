1d:Tacf,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is PORTADOR SOS?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR SOS is a premium time-critical air logistics platform for same-day air cargo, next flight out logistics, airport-to-airport cargo, hand carry, dangerous goods, battery cargo, and urgent business shipments."}},{"@type":"Question","name":"Is PORTADOR SOS a courier company?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR SOS is not positioned as a generic courier company. It focuses on urgent air-linked movement and human operations support when time cannot wait."}},{"@type":"Question","name":"What makes PORTADOR SOS different?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR SOS prioritizes urgent air cargo support, timing clarity, no avoidable hub delays, and live human ownership for urgent shipments."}},{"@type":"Question","name":"Who uses PORTADOR SOS?","acceptedAnswer":{"@type":"Answer","text":"Manufacturing, aviation, pharma, electronics, events, legal firms, SMEs, startups, travelers, students, and high-value cargo clients use PORTADOR SOS for urgent movement."}},{"@type":"Question","name":"Does PORTADOR SOS operate 24x7?","acceptedAnswer":{"@type":"Answer","text":"Yes. PORTADOR SOS is built around a 24x7 urgent support posture, subject to route, cargo type, airport, and pickup availability."}},{"@type":"Question","name":"Can PORTADOR SOS support dangerous goods, lithium batteries, or regulated cargo?","acceptedAnswer":{"@type":"Answer","text":"PORTADOR SOS can check dangerous goods, lithium batteries, and regulated cargo, but final movement depends on airline rules, approval, and service feasibility. MSDS or declaration may be required, and packing, documentation, and regulatory compliance must be verified before support."}},{"@type":"Question","name":"Does PORTADOR SOS offer next flight out logistics?","acceptedAnswer":{"@type":"Answer","text":"Yes. Next flight out logistics is one of PORTADOR SOS's core services for shipments that need the earliest feasible flight."}},{"@type":"Question","name":"Does PORTADOR SOS support airport-to-airport cargo?","acceptedAnswer":{"@type":"Answer","text":"Yes. PORTADOR SOS coordinates airport-to-airport cargo for eligible shipments and routes."}},{"@type":"Question","name":"What is the brand promise?","acceptedAnswer":{"@type":"Answer","text":"The brand promise is When Time Cannot Wait, meaning PORTADOR SOS is designed for shipment urgency rather than routine parcel movement."}},{"@type":"Question","name":"How do I start?","acceptedAnswer":{"@type":"Answer","text":"Call or WhatsApp operations with origin, destination, deadline, cargo details, weight, dimensions, and any regulated cargo declaration."}}]}a:["$","$1","c",{"children":[["$","main",null,{"children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1d"}}],["$","section",null,{"className":"relative overflow-hidden py-14 md:py-20","children":[["$","div",null,{"className":"airport-grid absolute inset-0 opacity-70"}],["$","div",null,{"className":"container-shell relative","children":[["$","p",null,{"className":"mb-4 text-xs font-bold uppercase tracking-[0.28em] text-[#e30613]","children":"About PORTADOR SOS"}],["$","h1",null,{"className":"max-w-4xl text-4xl font-black leading-tight text-white lg:text-5xl xl:text-6xl","children":"India's SOS Air Cargo Operations Platform"}],"$L1e"]}]]}],"$L1f","$L20","$L21","$L22","$L23","$L24","$L25"]}],null,"$L26"]}]
